{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "wip",
        "archived",
        "active"
      ]
    },
    "imageAlt": {
      "default": "",
      "type": "string"
    },
    "summary": {
      "type": "object",
      "properties": {
        "pl": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "required": [
        "pl",
        "en"
      ]
    },
    "description": {
      "type": "object",
      "properties": {
        "pl": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "required": [
        "pl",
        "en"
      ]
    },
    "technologies": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mainSkill": {
      "type": "string"
    },
    "duration": {
      "type": "object",
      "properties": {
        "pl": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "required": [
        "pl",
        "en"
      ]
    },
    "role": {
      "type": "object",
      "properties": {
        "pl": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "required": [
        "pl",
        "en"
      ]
    },
    "responsibilities": {
      "type": "object",
      "properties": {
        "pl": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "en": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "pl",
        "en"
      ]
    },
    "skills": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "level": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "order",
    "status",
    "summary",
    "description",
    "duration",
    "responsibilities"
  ]
}