---
import { getCollection } from "astro:content";
import { projectStatusLabels } from "@/lib/projectStatus";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="projects" class="projects" aria-labelledby="projects-title">
  <div class="projects__header">
    <h2 id="projects-title" class="projects__title">
      <span data-pl>Projekty</span>
      <span data-en>Projects</span>
    </h2>
  </div>

  <div class="projects__grid">
    {
      projects.map((project) => {
        const status = projectStatusLabels[project.data.status];
        const previewImage = `/images/${project.id}-preview.webp`;

        return (
          <a href={`/projects/${project.id}/`} class="project-card">
            <div class="project-card__media">
              <img
                src={previewImage}
                alt={project.data.imageAlt || project.data.title}
                loading="lazy"
                onerror="this.hidden = true; this.nextElementSibling.hidden = false;"
              />
              <span hidden>
                <span data-pl>Miejsce na obraz</span>
                <span data-en>Image placeholder</span>
              </span>
            </div>

            <div class="project-card__body">
              <div class="project-card__top">
                <h3 class="project-card__title">{project.data.title}</h3>
                <span
                  class:list={[
                    "status-pill",
                    `status-pill--${project.data.status}`,
                  ]}
                >
                  <span data-pl>{status.pl}</span>
                  <span data-en>{status.en}</span>
                </span>
              </div>

              <p class="project-card__summary" data-pl>
                {project.data.summary.pl}
              </p>
              <p class="project-card__summary" data-en>
                {project.data.summary.en}
              </p>
            </div>
          </a>
        );
      })
    }
  </div>
</section>

<style>
  .projects {
    min-width: 0;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 26%, transparent);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .projects__header {
    margin-bottom: 1.4rem;
  }

  .projects__title {
    color: var(--accent);
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    font-weight: 600;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card {
    min-width: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    background: color-mix(in srgb, var(--bg) 72%, var(--bg-card) 28%);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .project-card__media {
    height: clamp(13rem, 20vw, 22rem);
    display: grid;
    place-items: center;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    overflow: hidden;
  }

  .project-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .project-card__body {
    min-width: 0;
    padding: 1rem;
  }

  .project-card__top {
    min-width: 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .project-card__title {
    min-width: 0;
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .project-card__summary {
    color: var(--text-muted);
    line-height: 1.55;
    font-size: 0.86rem;
  }

  .status-pill {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    line-height: 1.2;
  }

  .status-pill--active {
    border-color: var(--accent);
    color: var(--accent);
  }

  .status-pill--wip {
    border-color: var(--accent-2);
    color: var(--accent-2);
  }

  .status-pill--archived {
    color: var(--text-muted);
  }

  @media (max-width: 620px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }

    .project-card__media {
      height: clamp(13rem, 62vw, 20rem);
    }
  }
</style>
