---
import { getCollection } from "astro:content";
import { projectStatusLabels } from "@/lib/projectStatus";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

const skillColors: Record<string, string> = {
  Lua: "#000080",
  Python: "#3572A5",
  python: "#3572A5",
  automation: "#89e051",
};
---

<section id="projects" class="projects" aria-labelledby="projects-title">
  <div class="projects__header">
    <h2 id="projects-title" class="projects__title">
      <span data-pl>Projekty</span>
      <span data-en>Projects</span>
    </h2>
  </div>

  <div class="projects__list">
    {
      projects.map((project) => {
        const status = projectStatusLabels[project.data.status];
        const mainSkill = project.data.mainSkill;
        const skillColor = mainSkill
          ? skillColors[mainSkill] || "var(--accent)"
          : "var(--accent)";

        return (
          <a href={`/projects/${project.id}/`} class="project-card">
            <div class="project-card__header">
              <div class="project-card__title-group">
                <span class="project-card__title">{project.data.title}</span>
                <span
                  class:list={[
                    "status-pill",
                    `status-pill--${project.data.status}`,
                  ]}
                >
                  <span data-pl>{status.pl}</span>
                  <span data-en>{status.en}</span>
                </span>
              </div>
            </div>

            <div class="project-card__body">
              <p class="project-card__summary" data-pl>
                {project.data.summary.pl}
              </p>
              <p class="project-card__summary" data-en>
                {project.data.summary.en}
              </p>
            </div>

            <div class="project-card__footer">
              {mainSkill && (
                <div class="project-card__skill">
                  <span
                    class="skill-dot"
                    style={`background-color: ${skillColor}`}
                  />
                  <span>{mainSkill}</span>
                </div>
              )}
            </div>
          </a>
        );
      })
    }
  </div>
</section>

<style>
  .projects {
    min-width: 0;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 15%, transparent);
    padding: clamp(1rem, 3vw, 2rem);
  }

  .projects__header {
    margin-bottom: clamp(1rem, 3vh, 2rem);
  }

  .projects__title {
    color: var(--accent);
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    font-weight: 600;
  }

  .projects__list {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1.5vh, 1rem);
  }

  .project-card {
    min-width: 0;
    padding: clamp(1rem, 2vh, 1.5rem);
    background: #0d1117;
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vh, 0.75rem);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .project-card:hover {
    background: #161b22;
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .project-card__title-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card__title {
    color: var(--accent);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .project-card__body {
    min-width: 0;
  }

  .project-card__summary {
    color: var(--text-muted);
    line-height: 1.5;
    font-size: 0.95rem;
    max-width: 100%;
  }

  .project-card__footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.3rem;
  }

  .project-card__skill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .skill-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .status-pill {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.12rem 0.5rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    line-height: 1.2;
    background: rgba(255, 255, 255, 0.05);
  }

  .status-pill--active {
    border-color: #238636;
    color: #3fb950;
  }

  .status-pill--wip {
    border-color: #9e6a03;
    color: #d29922;
  }

  .status-pill--archived {
    border-color: var(--border);
    color: var(--text-muted);
  }
</style>
