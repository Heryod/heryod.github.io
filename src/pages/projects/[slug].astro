---
import Base from "@/layout/Base.astro";
import { projectStatusLabels } from "@/lib/projectStatus";
import { pageTransition } from "@/lib/pageTransition";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const status = projectStatusLabels[project.data.status];
const projectImage = `/images/${project.id}.webp`;
const hideImage =
  project.id === "fivem-dreamlife" || project.id === "fivem-lastnight";
---

<Base
  title={`${project.data.title} — Heryod`}
  description={project.data.summary.en}
>
  <main
    class="project-page"
    transition:name="page-shell"
    transition:animate={pageTransition}
  >
    <a href="/#projects" class="project-page__back">
      <span data-pl>← Wróć do projektów</span>
      <span data-en>← Back to projects</span>
    </a>

    <header class="project-page__header">
      <div>
        <p class="project-page__eyebrow">
          <span data-pl>Projekt</span>
          <span data-en>Project</span>
        </p>
        <h1>{project.data.title}</h1>
      </div>

      <span class:list={["status-pill", `status-pill--${project.data.status}`]}>
        <span data-pl>{status.pl}</span>
        <span data-en>{status.en}</span>
      </span>
    </header>

    <div class="project-page__layout">
      <aside class="project-page__skills" aria-labelledby="project-skills">
        <h2 id="project-skills">
          <span data-pl>Użyte skills</span>
          <span data-en>Skills used</span>
        </h2>

        <div class="project-page__skill-list">
          {
            project.data.skills.map((skill) => (
              <div class="project-page__skill">
                <span>{skill.name}</span>
                {skill.level && (
                  <span
                    class="project-page__rating"
                    aria-label={`${skill.level} out of 5`}
                  >
                    {Array.from({ length: 5 }).map((_, index) => {
                      const isActive =
                        skill.level !== undefined && index < skill.level;
                      return (
                        <span
                          class:list={[
                            "project-page__dot",
                            isActive && "project-page__dot--active",
                          ]}
                          aria-hidden="true"
                        />
                      );
                    })}
                  </span>
                )}
              </div>
            ))
          }
        </div>
      </aside>

      <section class="project-page__details" aria-labelledby="project-details">
        {
          !hideImage && (
            <>
              <div class="project-page__media">
                <button
                  type="button"
                  class="project-page__media-trigger"
                  aria-label="Enlarge image"
                  onclick="document.getElementById('image-modal').showModal()"
                >
                  <img
                    src={projectImage}
                    alt={project.data.imageAlt || project.data.title}
                    onerror="this.closest('.project-page__media').querySelector('.project-page__media-trigger').style.display='none'; this.closest('.project-page__media').querySelector('[hidden]').hidden = false;"
                  />
                </button>
                <span hidden>
                  <span data-pl>Miejsce na obraz projektu</span>
                  <span data-en>Project image placeholder</span>
                </span>
              </div>

              <dialog id="image-modal" class="project-modal">
                <form method="dialog" class="project-modal__form">
                  <button class="project-modal__close" aria-label="Close">
                    &times;
                  </button>
                  <button
                    class="project-modal__overlay-btn"
                    aria-label="Close modal"
                  />
                </form>
                <div class="project-modal__content">
                  <img
                    src={projectImage}
                    alt={project.data.imageAlt || project.data.title}
                  />
                </div>
              </dialog>
            </>
          )
        }

        <h2 id="project-details">
          <span data-pl>Opis projektu</span>
          <span data-en>Project details</span>
        </h2>

        <p class="project-page__lead" data-pl>{project.data.description.pl}</p>
        <p class="project-page__lead" data-en>{project.data.description.en}</p>

        <div class="project-page__meta">
          <div>
            <h3>
              <span data-pl>Technologie</span>
              <span data-en>Technologies</span>
            </h3>
            <div class="project-page__tags">
              {
                project.data.technologies.map((technology) => (
                  <span>{technology}</span>
                ))
              }
            </div>
          </div>

          <div>
            <h3>
              <span data-pl>Czas trwania</span>
              <span data-en>Duration</span>
            </h3>
            <p data-pl>{project.data.duration.pl}</p>
            <p data-en>{project.data.duration.en}</p>
          </div>

          {
            project.data.role && (
              <div>
                <h3>
                  <span data-pl>Czym się zajmowałem</span>
                  <span data-en>My role</span>
                </h3>
                <p data-pl>{project.data.role.pl}</p>
                <p data-en>{project.data.role.en}</p>
              </div>
            )
          }
        </div>

        <div class="project-page__responsibilities">
          <h3>
            <span data-pl>Zakres prac</span>
            <span data-en>Responsibilities</span>
          </h3>

          <ul data-pl>
            {project.data.responsibilities.pl.map((item) => <li>{item}</li>)}
          </ul>
          <ul data-en>
            {project.data.responsibilities.en.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="project-page__content">
          <Content />
        </div>
      </section>
    </div>
  </main>
</Base>

<style>
  .project-page {
    width: min(100%, 1720px);
    margin: 0 auto;
    padding: clamp(5.5rem, 10vh, 7rem) clamp(1rem, 3vw, 3.5rem)
      clamp(3rem, 8vh, 5rem);
  }

  .project-page__back {
    display: inline-flex;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .project-page__back:hover {
    color: var(--accent);
  }

  .project-page__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 34%, transparent);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .project-page__eyebrow {
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.84rem;
    margin-bottom: 0.5rem;
  }

  .project-page__header h1 {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.1;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .project-page__layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.55fr) minmax(0, 2fr);
    gap: 1rem;
    align-items: start;
  }

  .project-page__skills,
  .project-page__details {
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 30%, transparent);
  }

  .project-page__skills {
    position: sticky;
    top: 5.5rem;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .project-page__skills h2,
  .project-page__details h2 {
    color: var(--accent);
    font-size: 1.35rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .project-page__skill-list {
    display: grid;
    gap: 0.8rem;
  }

  .project-page__skill {
    min-width: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    color: var(--text);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.88rem;
  }

  .project-page__rating {
    display: inline-flex;
    gap: 0.25rem;
  }

  .project-page__dot {
    width: 0.5rem;
    height: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg);
  }

  .project-page__dot--active {
    border-color: var(--accent);
    background: var(--accent);
  }

  .project-page__details {
    min-width: 0;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .project-page__media {
    aspect-ratio: 16 / 8;
    display: grid;
    place-items: center;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.86rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--bg) 78%, var(--bg-card) 22%);
  }

  .project-page__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .project-page__media-trigger {
    all: unset;
    cursor: pointer;
    width: 100%;
    height: 100%;
    display: block;
    transition: transform 0.2s ease;
  }

  .project-page__media-trigger:hover {
    transform: scale(1.02);
  }

  .project-modal {
    padding: 0;
    border: none;
    background: transparent;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    overflow: hidden;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }

  .project-modal__form {
    margin: 0;
  }

  .project-modal__overlay-btn {
    all: unset;
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    cursor: zoom-out;
    z-index: 1;
  }

  .project-modal::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .project-modal__close {
    position: fixed;
    top: 2rem;
    right: 2rem;
    background: #fff;
    color: #000;
    border: none;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    font-size: 2rem;
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 10;
    transition: transform 0.2s ease;
  }

  .project-modal__close:hover {
    transform: scale(1.1) rotate(90deg);
  }

  .project-modal__content {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: 2rem;
    pointer-events: none; /* Let clicks pass to overlay-btn */
  }

  .project-modal__content img {
    position: relative;
    z-index: 2;
    max-width: 95vw;
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
    pointer-events: auto; /* Re-enable for image itself though clicks will mostly hit overlay */
  }

  .project-page__lead {
    color: var(--text);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .project-page__meta {
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .project-page__meta > div,
  .project-page__responsibilities,
  .project-page__content {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .project-page__meta h3,
  .project-page__responsibilities h3 {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.7rem;
  }

  .project-page__meta p,
  .project-page__responsibilities li,
  .project-page__content {
    color: var(--text);
    line-height: 1.7;
  }

  .project-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-page__tags span {
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    padding: 0.25rem 0.7rem;
  }

  .project-page__responsibilities ul {
    margin-left: 1rem;
  }

  .project-page__content {
    margin-top: 1.5rem;
  }

  .project-page__content :global(h2),
  .project-page__content :global(h3) {
    color: #fff;
    font-weight: 600;
    margin: 1.25rem 0 0.7rem;
  }

  .project-page__content :global(p) {
    margin-bottom: 1rem;
  }

  .status-pill {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.22rem 0.65rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .status-pill--active {
    border-color: var(--accent);
    color: var(--accent);
  }

  .status-pill--wip {
    border-color: var(--accent-2);
    color: var(--accent-2);
  }

  .status-pill--archived {
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .project-page {
      padding-top: 5.5rem;
    }

    .project-page__header {
      flex-direction: column;
    }

    .project-page__layout {
      grid-template-columns: 1fr;
    }

    .project-page__skills {
      position: static;
    }
  }
</style>
